# =============================================================================
# COPY THIS FILE → rename copy to `.env`  (or merge lines into existing `.env`)
# =============================================================================
# Then run:  npm run env:check
# =============================================================================

# --- Mode A: Docker Postgres (RECOMMENDED for first-time tables) ------------
#   npm run db:up   then use these two lines as DATABASE_URL + DIRECT_URL:
DATABASE_URL="postgresql://apop:apop@localhost:5432/apop?schema=public"
DIRECT_URL="postgresql://apop:apop@localhost:5432/apop?schema=public"

# --- Mode B: Supabase Postgres (replace password + ref; needs reachable :5432) -
# DATABASE_URL="postgresql://postgres:PASTE_DB_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?schema=public&sslmode=require"
# DIRECT_URL="postgresql://postgres:PASTE_DB_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?schema=public&sslmode=require"

# Supabase API (optional — for @supabase/supabase-js, not for Prisma)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_REPLACE_WITH_YOURS"
SUPABASE_SECRET_KEY=""

# Vercel (optional — Deploy + auto-link Cursor Preview URL in APOP)
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""
# Primary: APOP “Deploy” uses this hook. In Vercel, each hook is tied to ONE branch — use a Preview/staging
# hook here if you want rebuilds to hit that environment (not production). Leave production hook below unset
# unless you need a fallback when this is empty.
VERCEL_DEPLOY_HOOK_URL=""
# Fallback only when VERCEL_DEPLOY_HOOK_URL is empty — e.g. Production deploy hook for main
VERCEL_PRODUCTION_DEPLOY_HOOK_URL=""
VERCEL_WEBHOOK_SECRET=""

# Delivery defaults (site-apop) — override if you use another repo / URL
APOP_DELIVERY_REPO_URL=""
APOP_DELIVERY_PRODUCTION_URL=""

# APOP app URL — where APOP is hosted. Site-apop POSTs tracking events here.
# Set in APOP .env AND site-apop as NEXT_PUBLIC_APOP_APP_URL for live data.
APOP_APP_URL="https://localhost:3000"

# CORS: comma-separated origins allowed to POST to /api/tracking/events.
# Default: APOP_DELIVERY_PRODUCTION_URL + site-apop.vercel.app
# APOP_TRACKING_ALLOWED_ORIGINS="https://site-apop.vercel.app,https://site-apop-xxx.vercel.app"

# Cursor Cloud Agents — https://cursor.com/docs/background-agent/api/endpoints
CURSOR_API_KEY=""
# Optional; when empty, APOP uses APOP_DELIVERY_REPO_URL or the built-in site-apop GitHub URL
CURSOR_BUILD_REPOSITORY=""
CURSOR_BUILD_REF="main"
# Optional explicit model (omit for Cursor default)
CURSOR_AGENT_MODEL=""
# Webhook secret for Cursor Cloud → APOP callbacks (>= 32 chars).
# If empty, APOP reuses CURSOR_API_KEY. Cursor calls /api/webhooks/cursor
# when an agent finishes or errors — this triggers auto-deploy without polling.
CURSOR_WEBHOOK_SECRET=""

# OpenAI — value analyst prefers ChatGPT API when OPENAI_API_KEY is set
OPENAI_API_KEY=""
OPENAI_MODEL=""

# Anthropic — fallback if OpenAI is unset or fails
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL=""
