{
  "name": "apop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "dev:fast": "next dev",
    "dev:3020": "rm -rf .next && next dev -p 3020",
    "dev:3020:fast": "next dev -p 3020",
    "dev:3000": "rm -rf .next && next dev -p 3000",
    "dev:turbo": "rm -rf .next && next dev --turbopack",
    "dev:clean": "rm -rf .next && next dev",
    "dev:fresh": "npm run port:free && rm -rf .next && next dev",
    "dev:fresh:3020": "npm run port:free && rm -rf .next && next dev -p 3020",
    "port:free": "node scripts/free-apop-ports.mjs",
    "build": "next build",
    "build:clean": "rm -rf .next && next build",
    "start": "next start",
    "lint": "eslint",
    "env:check": "node scripts/check-apop-env.mjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "prisma db push --force-reset",
    "db:clear-features": "node scripts/clear-all-features.mjs",
    "postinstall": "prisma generate",
    "setup:local": "npm run db:up && prisma db push",
    "demo:local": "node scripts/demo-local.mjs",
    "e2e": "node scripts/e2e-workflow.mjs",
    "setup:docker-db": "bash scripts/setup-docker-db.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.5.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.99.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.483.0",
    "next": "^15.2.3",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@tailwindcss/postcss": "^4.0.14",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.0.14",
    "typescript": "^5.8.2"
  }
}
